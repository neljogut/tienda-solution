rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario está logueado
    function isAuth() {
      return request.auth != null;
    }

    // Reglas para la colección de Usuarios
    match /users/{userId} {
      // Un usuario puede leer y escribir su propio documento
      allow read, write: if isAuth() && request.auth.uid == userId;
      // Administradores podrían leer todo (requeriría custom claims o similar en producción)
      allow read, write: if isAuth(); 
    }

    // Reglas para Productos
    match /products/{productId} {
      // Cualquier persona (incluso invitados) puede ver el catálogo
      allow read: if true;
      // Solo usuarios autenticados pueden crear o modificar productos (luego se puede restringir a 'owner')
      allow write: if isAuth();
    }

    // Reglas para Categorías
    match /categories/{categoryId} {
      // Cualquier persona (incluso invitados) puede leer las categorías
      allow read: if true;
      allow write: if isAuth();
    }

    // Reglas para Configuración (Settings)
    match /settings/{settingId} {
      // Cualquier persona (incluso invitados) puede leer las configuraciones de negocio y precios
      allow read: if true;
      allow write: if isAuth();
    }

    // Reglas para Pedidos
    match /orders/{orderId} {
      allow read, write: if isAuth();
    }

    // Credenciales privadas — solo Cloud Functions (Admin SDK)
    match /settings_private/{docId} {
      allow read, write: if false;
    }

    // Intents y pagos online — lectura autenticada, escritura solo Functions (Admin SDK)
    match /payment_intents/{intentId} {
      allow read: if isAuth();
      allow write: if false;
    }

    match /online_payments/{paymentId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Reglas para Inventario (Filamentos y otros)
    match /inventory/{itemId} {
      allow read, write: if isAuth();
    }

    // Reglas para Caja Diaria
    match /cash_sessions/{sessionId} {
      allow read, write: if isAuth();
    }
    match /cash_movements/{movementId} {
      allow read, write: if isAuth();
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStaff() {
      return isAuth() && userDoc().role in ['owner', 'employee'];
    }

    match /notifications/{notificationId} {
      allow read: if isAuth() && resource.data.recipientUid == request.auth.uid;
      allow create: if isAuth() && (
        request.resource.data.recipientUid == request.auth.uid
        || isStaff()
        || userDoc().role == 'client'
      );
      allow update: if isAuth()
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuth() && resource.data.recipientUid == request.auth.uid;
    }
    
    // Cualquier otra colección, por defecto bloqueada a no logueados, abierta a logueados
    match /{document=**} {
      allow read, write: if isAuth();
    }
  }
}
