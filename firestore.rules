rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return signedIn() ? userDoc().data.role : 'guest';
    }

    function isOwner() {
      return signedIn() && role() == 'owner';
    }

    function isEmployee() {
      return signedIn() && role() == 'employee';
    }

    function isClient() {
      return signedIn() && role() == 'client';
    }

    function hasPermission(permission) {
      return isOwner() || (isEmployee() && userDoc().data.permissions[permission] == true);
    }

    function ownsCustomer(customerId) {
      return isClient() && userDoc().data.customerId == customerId;
    }

    match /users/{userId} {
      allow read: if isOwner() || request.auth.uid == userId || hasPermission('manageEmployees');
      allow create, update, delete: if isOwner();
    }

    match /customers/{customerId} {
      allow read: if isOwner() || hasPermission('viewClients') || ownsCustomer(customerId);
      allow create: if isOwner() || hasPermission('createClients') || request.auth.uid == customerId;
      allow update: if isOwner() || hasPermission('editClients') || ownsCustomer(customerId);
      allow delete: if isOwner();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isOwner() || hasPermission('createProducts');
      allow update: if isOwner() || hasPermission('editProducts');
      allow delete: if isOwner();
    }

    match /orders/{orderId} {
      allow read: if isOwner() || hasPermission('viewOrders') || ownsCustomer(resource.data.customerId);
      allow create: if isOwner() || hasPermission('createOrders') || ownsCustomer(request.resource.data.customerId);
      allow update: if isOwner() || hasPermission('editOrders') || hasPermission('registerPayments');
      allow delete: if isOwner();
    }

    match /payments/{paymentId} {
      allow read: if isOwner() || hasPermission('registerPayments') || ownsCustomer(resource.data.customerId);
      allow create: if isOwner() || hasPermission('registerPayments');
      allow update, delete: if isOwner();
    }

    match /filaments/{id} {
      allow read: if isOwner() || hasPermission('viewInventory');
      allow write: if isOwner() || hasPermission('modifyInventory');
    }

    match /supplies/{id} {
      allow read: if isOwner() || hasPermission('viewInventory');
      allow write: if isOwner() || hasPermission('modifyInventory');
    }

    match /inventory_movements/{id} {
      allow read: if isOwner() || hasPermission('viewInventoryMovements');
      allow create: if isOwner() || hasPermission('modifyInventory') || hasPermission('createOrders');
      allow update, delete: if isOwner();
    }

    match /cash_sessions/{id} {
      allow read: if isOwner() || hasPermission('viewCurrentCash') || hasPermission('viewCashHistory');
      allow create: if isOwner() || hasPermission('openCash');
      allow update: if isOwner() || hasPermission('closeCash');
      allow delete: if isOwner();
    }

    match /cash_movements/{id} {
      allow read: if isOwner() || hasPermission('viewCurrentCash') || hasPermission('viewCashHistory');
      allow create: if isOwner() || hasPermission('registerPayments') || hasPermission('openCash');
      allow update, delete: if isOwner();
    }

    match /business_settings/{id} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /pricing_settings/{id} {
      allow read: if isOwner() || hasPermission('viewPricingSettings');
      allow write: if isOwner();
    }

    match /exchange_rates/{id} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /pdf_documents/{id} {
      allow read: if isOwner()
        || hasPermission('viewInternalPdfs')
        || (resource.data.visibility == 'customer' && ownsCustomer(resource.data.customerId));
      allow create: if isOwner() || hasPermission('downloadInternalPdfs');
      allow update, delete: if isOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
