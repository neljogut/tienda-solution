{
  "name": "solution-3d",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "node scripts/generate-fcm-sw.mjs && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean": "node -e \"['dist', 'node_modules'].forEach(p => require('fs').rmSync(p, { recursive: true, force: true }))\"",
    "clean:backup": "node scripts/clean-backup.mjs",
    "import:data": "node scripts/import-gestion-data.mjs",
    "import:data:execute": "node scripts/import-gestion-data.mjs --execute",
    "import:movements": "node scripts/import-gestion-data.mjs --execute --only=inventory_movements",
    "fix:product-materials": "node scripts/fix-product-materials.mjs",
    "fix:product-materials:execute": "node scripts/fix-product-materials.mjs --execute",
    "fix:filament-prices": "node scripts/fix-filament-prices.mjs --execute",
    "fix:product-categories": "node scripts/fix-product-categories.mjs --execute",
    "build:solution": "node scripts/build-solution.mjs",
    "deploy": "node scripts/deploy.mjs",
    "deploy:force": "node scripts/deploy.mjs --force",
    "deploy:mp": "node scripts/deploy-mp.mjs"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "firebase": "^12.14.0",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^15.20.0",
    "globals": "^17.6.0",
    "google-auth-library": "^10.7.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
