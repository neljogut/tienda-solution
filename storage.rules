rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // PDF de comprobante generado en checkout (cliente autenticado)
    match /orders/{orderId}/comprobante-cliente.pdf {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
